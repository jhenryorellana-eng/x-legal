# UsaLatinoPrime V2 — environment inventory (DOC-82 / DOC-27 §7.1)
# Copy to .env.local (git-ignored) and fill in. NEVER commit real values.
# Twilio Verify (SMS OTP) credentials live in Supabase Auth config, NOT here.

# ── Core (required at boot — validated in backend/platform/env.ts) ──────────
NEXT_PUBLIC_SUPABASE_URL=https://uexxyokexcamyjcknxua.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# AES-256-GCM master key for PII (32 bytes base64): openssl rand -base64 32
ENCRYPTION_KEY=
# Only during key rotation (DOC-27 §2.5)
# ENCRYPTION_KEY_PREVIOUS=

# ── Stripe (F6) ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Twilio Messaging — transactional SMS only (F2) ──────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# ── Upstash QStash — async jobs (F3+) ────────────────────────────────────────
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── Upstash Redis — rate limiting (F0, OTP) ──────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── LiveKit (F7) ─────────────────────────────────────────────────────────────
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# ── Resend (F0 staff emails, F6 campaigns) ───────────────────────────────────
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# ── IA (F4) — only importable from ai-engine/jobs (RNF-041) ──────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Urlbox — HTML→PDF renderer for cited exhibits (memo annexes) ─────────────
# Required by src/backend/platform/renderer.ts. Without it, exhibit capture fails
# (the memo still generates; annexes are marked failed and can be retried/uploaded).
URLBOX_SECRET=

# ── SaaS Abogados (F5) ───────────────────────────────────────────────────────
ABOGADOS_API_KEY=
ABOGADOS_WEBHOOK_SECRET=

# ── Web Push (F7) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Feature flags (client-exposed) ───────────────────────────────────────────
# "Me interesa" lead CTA on the service detail screen (DOC-51 §7, nota H-7 / PS-3).
# The lead action arrives in F3; while false the CTA renders disabled. Set "true"
# to enable once API-LEAD (client) exists.
NEXT_PUBLIC_FEATURE_INTERES=false

# ── Dev-only harnesses (NEVER true in staging/production) ────────────────────
# Enables /admin-preview/[view] route (M-4: two-factor guard — NODE_ENV≠production AND flag=true)
# ENABLE_ADMIN_PREVIEW=true
# ENABLE_VENTAS_PREVIEW=true
