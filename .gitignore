# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# serwist (PWA) build artifacts — generated by `next build` from src/app/sw.ts.
# public/sw.js is committed as the dev push-only worker (Serwist is disabled in
# dev); a production build overwrites it, so restore it before resuming dev.
/public/sw.js.map
/public/swe-worker-*.js

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local MCP config — carries a Supabase access token; never commit
.mcp.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright artifacts
/test-results/
/playwright-report/
/.playwright-mcp/
# playwright auth state (session cookies — never commit)
/e2e/.auth/

# Real Chase Zelle emails used as parser regression fixtures — contain client
# PII (names, amounts, txn ids). Tests skip gracefully when absent (CI runs
# the synthetic structural suite only).
src/backend/modules/zelle-recon/__tests__/fixtures/*.eml

# Evidence session artifacts (real JWTs / cookies — never commit)
docs/_evidence/**/*cookie*.json
docs/_evidence/**/*cookie*.txt
docs/_evidence/**/*-fresh.txt
docs/_evidence/**/*-LLENADO.pdf
docs/_evidence/**/*-APP-GENERADO.pdf
docs/_evidence/f5-compile/

# Memoria del proyecto (docs/historial/) — registro interno local de sesiones/cambios,
# orientado a spec-driven development. Es contexto para Claude en esta máquina; NO se sube.
docs/historial/

# Local artifacts (screenshots, scratch PDFs, build/dev logs) — not source
/*.png
/*.jpg
/*.jpeg
/*.pdf
*.log
docs/_evidence/**/*.png
docs/_evidence/**/*.log
docs/_evidence/**/*.json
docs/_evidence/**/*.pdf
docs/_evidence/_*.json
