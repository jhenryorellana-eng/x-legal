{
  "name": "usalatino-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:e2e": "cross-env AI_E2E_STUB=1 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:rls": "supabase test db",
    "db:types": "supabase gen types typescript --project-id uexxyokexcamyjcknxua --schema public > src/shared/database.types.ts",
    "db:types:local": "supabase gen types typescript --local --schema public > src/shared/database.types.ts",
    "db:migrate": "supabase migration up && npm run db:types:local",
    "check:drift": "node scripts/check-db-drift.mjs",
    "check:i18n": "node scripts/check-i18n-keys.mjs",
    "check:assets": "node scripts/check-asset-size.mjs"
  },
